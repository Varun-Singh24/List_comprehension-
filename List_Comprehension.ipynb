    {
      "cell_type": "markdown",
      "source": [
        "To find out the square of the above list We use list comprehension"
      ],
      "metadata": {
        "id": "1GjQ0-JrjFsf"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Using the loop\n",
        "for i in ls :\n",
        "  print(i**2, end=\" \")"
      ],
